# LLM Provider Configuration
# Choose one provider only: `anthropic` | `openai_compat`.
# Copy these variables to your .env file and replace placeholder values.

## Option 1: Use Anthropic Directly
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
# ANTHROPIC_MODEL=claude-3-7-sonnet-20250219 # Optional, uses default if empty

## Option 2: Use OpenAI-Compatible API (Recommended，e.g. OpenRouter) 
LLM_PROVIDER=openai_compat
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-REPLACE_ME
LLM_MODEL=anthropic/claude-3.7-sonnet